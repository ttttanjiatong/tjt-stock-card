# Streamlit Cloud 部署时的 Secrets 配置参考。
#
# ⚠️ 不要把真实 token 写进这个文件，这个文件是模板。
# 真实的 secrets 在 Streamlit Cloud 的 Web 界面里配（Settings → Secrets），
# 直接粘贴下面的内容并替换 token。

ANTHROPIC_AUTH_TOKEN = "ark-xxxxxxxx-填入方舟控制台获取的-key-xxxxxxxx"
ANTHROPIC_BASE_URL = "https://ark.cn-beijing.volces.com/api/coding"
ANTHROPIC_MODEL = "kimi-k2.6"
ANTHROPIC_EVALUATOR_MODEL = "glm-5.1"
AI_DISABLE_THINKING = "1"
