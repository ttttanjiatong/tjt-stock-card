# ===== 方舟 Coding Plan（默认）=====
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding

# Executor Agent 模型（主程序）
ANTHROPIC_MODEL=kimi-k2.6
# Evaluator Agent 模型（评分），与 Executor 区分避免自评偏置；留空则 fallback 到 ANTHROPIC_MODEL
ANTHROPIC_EVALUATOR_MODEL=glm-5.1

# ===== 如使用官方 Anthropic API，改用以下配置 =====
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_EVALUATOR_MODEL=claude-sonnet-4-6
